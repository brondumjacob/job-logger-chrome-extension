# macOS
.DS_Store

# Node
node_modules/
npm-debug.log*

# Build output
dist/

# Environment files
.env
.env.local

# IDE
.vscode/
.idea/

# Claude Code local/machine-specific config (holds MCP server credentials —
# never commit; see .claude/settings.json for the shared, secret-free config)
.claude/settings.local.json

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp

# Playwright browser binary (~196MB, manually downloaded for the sandboxed
# test harness — see tests/README.md). Never commit this.
tests/chromium-linux-arm64.zip

# Extension signing keypair (pins a stable extension ID for LOCAL unpacked
# loads only — the Chrome Web Store rejects any upload whose manifest
# contains a "key" field, so this ID does NOT carry through to the
# published extension; see docs/PUBLISHING_CHECKLIST.md). manifest.json's
# "key" field holds the PUBLIC half and is fine to commit. The private key
# itself should never be committed.
keys/extension-key.pem

# CWS upload package (built by npm run package:cws — has "key" stripped)
job-application-logger-cws.zip
